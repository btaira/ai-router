# Copy to .env and fill in the keys for the providers you want enabled.
# A provider with no key set will fail fast in stage 1 with a clear
# "missing API key" error instead of blocking the other five providers.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# DeepSeek, MiniMax, and Moonshot (Kimi) are routed through OpenRouter
# (openrouter.ai) rather than called directly — one key covers all three.
OPENROUTER_API_KEY=

# Optional overrides
# AI_ROUTER_CONFIG=/app/backend/config/providers.yaml
# AI_ROUTER_DB=/app/backend/data/ai_router.db
# AI_ROUTER_ENV=/app/.env

# You don't have to hand-edit this file: "Model settings" > API key in the
# running app writes straight into this same .env file and applies the
# change to the live process immediately, no restart needed. Handy for
# swapping/rotating a key without shell access. Docker Compose bind-mounts
# this file into the container specifically so those writes land here on
# the host, not just inside the container.
