# Copy to .env and fill in the keys for the providers you want enabled.
# A provider with no key set will fail fast in stage 1 with a clear
# "missing API key" error instead of blocking the other five providers.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# DeepSeek, MiniMax, and Moonshot (Kimi) are routed through OpenRouter
# (openrouter.ai) rather than called directly — one key covers all three.
OPENROUTER_API_KEY=

# Optional overrides
# AI_ROUTER_CONFIG=/app/backend/config/providers.yaml
# AI_ROUTER_DB=/app/backend/data/ai_router.db
# AI_ROUTER_KEYS=/app/backend/config/keys.env

# None of the above are required — every key can also be pasted into
# "Model settings" > API key in the running app instead. That writes to
# backend/config/keys.env (git-ignored, created automatically) rather than
# this file, and overrides whatever's set here immediately, no restart
# needed. This file is only for keys you want baked in at deploy time.
