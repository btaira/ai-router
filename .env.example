# Copy to .env and fill in the keys for the providers you want enabled.
# A provider with no key set will fail fast in stage 1 with a clear
# "missing API key" error instead of blocking the other five providers.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
MINIMAX_API_KEY=
MOONSHOT_API_KEY=

# Optional overrides
# AI_ROUTER_CONFIG=/app/backend/config/providers.yaml
# AI_ROUTER_DB=/app/backend/data/ai_router.db
